<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinIconFinder.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinIconFinder"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinIconFinder.Models"
    Background="Transparent"
    mc:Ignorable="d">

    <NavigationView
        x:Name="NavView"
        AlwaysShowHeader="False"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="Top"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.MenuItems>
            <NavigationViewItem
                x:Name="SearchModeNavItem"
                Content="Search &amp; Draw"
                ToolTipService.ToolTip="Search by name or draw a sketch">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE773;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                x:Name="SimilarityMapNavItem"
                Content="Similarity Map"
                ToolTipService.ToolTip="Explore icons arranged by visual similarity">
                <NavigationViewItem.Icon>
                    <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE800;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>

            <!--
                ══════════════════════════════════════════════════════════════
                SEARCH + DRAW PANEL
                ══════════════════════════════════════════════════════════════
            -->
            <Grid x:Name="SearchModePanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid
                    Grid.Column="0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Search box  -->
                    <TextBox
                        x:Name="SearchBox"
                        Grid.Row="0"
                        Margin="8,8,8,4"
                        AutomationProperties.AutomationId="SearchBox"
                        PlaceholderText="Search icons…"
                        Text="{x:Bind ViewModel.SearchQuery,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}" />

                    <!--  Result count  -->
                    <TextBlock
                        Grid.Row="1"
                        Margin="12,0,8,4"
                        Opacity="0.6"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind local:MainPage.FormatCount(ViewModel.FilteredIcons.Count),
                                      Mode=OneWay}" />

                    <!--  Icon list  -->
                    <ListView
                        x:Name="IconListView"
                        Grid.Row="2"
                        AutomationProperties.AutomationId="IconListView"
                        ItemsSource="{x:Bind ViewModel.FilteredIcons,
                                             Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedIcon,
                                              Mode=TwoWay}"
                        SelectionMode="Single">

                        <ListView.ItemContainerStyle>
                            <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="8,2" />
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:FluentIcon">
                                <Grid
                                    Height="52"
                                    ColumnSpacing="8"
                                    RightTapped="IconItem_RightTapped">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Accent tint when this icon is a match  -->
                                    <Border
                                        Grid.ColumnSpan="3"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="{ThemeResource ControlCornerRadius}"
                                        IsHitTestVisible="False"
                                        Opacity="{x:Bind local:MainPage.MatchOpacity(IsMatch),
                                                         Mode=OneWay}" />

                                    <!--  Glyph preview  -->
                                    <Border
                                        Grid.Column="0"
                                        Width="36"
                                        Height="36"
                                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        CornerRadius="{ThemeResource ControlCornerRadius}">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="ms-appx:///Assets/FluentSystemIcons-Regular.ttf#FluentSystemIcons-Regular"
                                            FontSize="22"
                                            Text="{x:Bind GlyphString}" />
                                    </Border>

                                    <!--  Name + codepoint  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock
                                            Style="{StaticResource BodyStrongTextBlockStyle}"
                                            Text="{x:Bind DisplayName}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Opacity="0.6"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind CodepointHex}" />
                                    </StackPanel>

                                    <!--  Match score badge  -->
                                    <Border
                                        Grid.Column="2"
                                        Padding="6,2"
                                        VerticalAlignment="Center"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        CornerRadius="4"
                                        Visibility="{x:Bind local:MainPage.BoolToVisibility(IsMatch),
                                                            Mode=OneWay}">
                                        <TextBlock
                                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                            Style="{StaticResource CaptionTextBlockStyle}"
                                            Text="{x:Bind local:MainPage.FormatScore(MatchScore),
                                                          Mode=OneWay}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!--
                    ══════════════════════════════════════════════════════════════
                    RIGHT PANEL — drawing canvas
                    ══════════════════════════════════════════════════════════════
                -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Toolbar  -->
                    <Grid
                        Grid.Row="0"
                        Padding="12,8,12,8"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  Quick copy + explore buttons — visible only when an icon is selected  -->
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            Visibility="{x:Bind local:MainPage.HasSelectedIcon(ViewModel.SelectedIcon),
                                                Mode=OneWay}">
                            <Button
                                AutomationProperties.AutomationId="CopyGlyphButton"
                                AutomationProperties.Name="Copy glyph code"
                                Click="CopyGlyph_Click"
                                Content="&#xE8C8;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Copy glyph code" />
                            <Button
                                AutomationProperties.AutomationId="CopyXamlButton"
                                AutomationProperties.Name="Copy XAML FontIcon"
                                Command="{x:Bind ViewModel.CopyAsXamlCommand}"
                                Content="&#xE943;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Copy as XAML FontIcon" />
                            <Button
                                AutomationProperties.AutomationId="CopyPngButton"
                                AutomationProperties.Name="Copy PNG"
                                Click="CopyPng_Click"
                                Content="&#xEB9F;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Copy as PNG" />
                            <Button
                                AutomationProperties.AutomationId="CopySvgButton"
                                AutomationProperties.Name="Copy SVG"
                                Command="{x:Bind ViewModel.CopyAsSvgCommand}"
                                Content="&#xE71B;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Copy as SVG" />

                            <Rectangle
                                Width="1"
                                Margin="4,6,4,6"
                                Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!--  Explore the selected icon's visual neighborhood in map mode  -->
                            <Button
                                x:Name="ExploreInMapButton"
                                AutomationProperties.AutomationId="ExploreInMapButton"
                                AutomationProperties.Name="Explore similar icons in map"
                                Click="ExploreInMap_Click"
                                ToolTipService.ToolTip="Explore similar icons in Similarity Map">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="14"
                                        Glyph="&#xE81E;" />
                                    <TextBlock VerticalAlignment="Center" Text="Explore in Map" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock
                            x:Name="StatusTextBlock"
                            Grid.Column="1"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Opacity="0.7"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind ViewModel.StatusText,
                                          Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />

                        <!--  Drawing tools: undo, clear, pen size, mirror  -->
                        <StackPanel
                            Grid.Column="2"
                            Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="4">
                            <Button
                                x:Name="UndoButton"
                                AutomationProperties.AutomationId="UndoButton"
                                AutomationProperties.Name="Undo last stroke"
                                Click="UndoStroke_Click"
                                Content="&#xE7A7;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Undo last stroke (Ctrl+Z)">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Z" Modifiers="Control" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button
                                x:Name="ClearButton"
                                AutomationProperties.AutomationId="ClearButton"
                                AutomationProperties.Name="Clear canvas"
                                Command="{x:Bind ViewModel.ClearCanvasCommand}"
                                Content="Clear">
                                <Button.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="L" Modifiers="Control" />
                                </Button.KeyboardAccelerators>
                            </Button>
                            <Button
                                x:Name="RotateButton"
                                AutomationProperties.AutomationId="RotateButton"
                                AutomationProperties.Name="Rotate ink 90 degrees"
                                Click="RotateInk_Click"
                                Content="&#xE7AD;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                ToolTipService.ToolTip="Rotate sketch 90° clockwise" />

                            <Rectangle
                                Width="1"
                                Margin="4,6,4,6"
                                Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <ToggleButton
                                x:Name="PenSmallButton"
                                Width="32"
                                Height="32"
                                Padding="0"
                                AutomationProperties.AutomationId="PenSmallButton"
                                AutomationProperties.Name="Small pen"
                                Click="PenSmall_Click"
                                ToolTipService.ToolTip="Small pen (6px)">
                                <Ellipse
                                    Width="7"
                                    Height="7"
                                    Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </ToggleButton>
                            <ToggleButton
                                x:Name="PenMediumButton"
                                Width="32"
                                Height="32"
                                Padding="0"
                                AutomationProperties.AutomationId="PenMediumButton"
                                AutomationProperties.Name="Medium pen"
                                Click="PenMedium_Click"
                                ToolTipService.ToolTip="Medium pen (10px)">
                                <Ellipse
                                    Width="11"
                                    Height="11"
                                    Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </ToggleButton>
                            <ToggleButton
                                x:Name="PenLargeButton"
                                Width="32"
                                Height="32"
                                Padding="0"
                                AutomationProperties.AutomationId="PenLargeButton"
                                AutomationProperties.Name="Large pen"
                                Click="PenLarge_Click"
                                ToolTipService.ToolTip="Large pen (16px)">
                                <Ellipse
                                    Width="16"
                                    Height="16"
                                    Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                            </ToggleButton>

                            <Rectangle
                                Width="1"
                                Margin="4,6,4,6"
                                Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <CheckBox
                                VerticalAlignment="Center"
                                AutomationProperties.AutomationId="MirrorMatchToggle"
                                AutomationProperties.Name="Try match mirrors"
                                Content="Try mirrors"
                                IsChecked="{x:Bind ViewModel.TryMatchMirrors,
                                                   Mode=TwoWay}"
                                ToolTipService.ToolTip="Also test horizontally and vertically flipped versions of your sketch to improve matching" />
                        </StackPanel>
                    </Grid>

                    <!--  Canvas layer: Win2D CanvasControl for freehand drawing  -->
                    <Grid
                        x:Name="CanvasHost"
                        Grid.Row="1"
                        SizeChanged="CanvasHost_SizeChanged">

                        <canvas:CanvasControl
                            x:Name="DrawingCanvas"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            AutomationProperties.AutomationId="DrawingCanvas"
                            Draw="DrawingCanvas_Draw"
                            PointerCaptureLost="DrawingCanvas_PointerCaptureLost"
                            PointerMoved="DrawingCanvas_PointerMoved"
                            PointerPressed="DrawingCanvas_PointerPressed"
                            PointerReleased="DrawingCanvas_PointerReleased" />

                        <!--  Empty-state hint (centred over the square canvas)  -->
                        <TextBlock
                            x:Name="EmptyStateText"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Opacity="0.35"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="✏️  Draw within the guide lines" />

                        <!--  Guide legend — anchored to bottom of the host, not the canvas  -->
                        <StackPanel
                            Margin="0,0,0,6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            IsHitTestVisible="False"
                            Opacity="0.55"
                            Orientation="Horizontal"
                            Spacing="16">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <Rectangle
                                    Width="18"
                                    Height="1"
                                    VerticalAlignment="Center"
                                    Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Canvas bounds" />
                            </StackPanel>
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <Path
                                    VerticalAlignment="Center"
                                    Data="M0,0.5 L4,0.5 M6,0.5 L10,0.5 M12,0.5 L16,0.5 M18,0.5 L22,0.5"
                                    Stroke="#0078D4"
                                    StrokeThickness="1.5" />
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}" Text="Icon safe area" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>

                    <!--
                        ══════════════════════════════════════════════════════════
                        Init progress overlay (covers both rows while loading)
                        ══════════════════════════════════════════════════════════
                    -->
                    <Grid
                        x:Name="LoadingOverlay"
                        Grid.RowSpan="2"
                        Background="{ThemeResource LayerFillColorDefaultBrush}">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="16">
                            <ProgressRing
                                Width="48"
                                Height="48"
                                IsActive="True" />
                            <TextBlock
                                x:Name="LoadingText"
                                HorizontalAlignment="Center"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind local:MainPage.FormatLoading(ViewModel.LoadingPhase,
                                              ViewModel.InitProgress),
                                              Mode=OneWay}" />
                            <ProgressBar
                                Width="200"
                                Maximum="100"
                                Minimum="0"
                                Value="{x:Bind ViewModel.InitProgress,
                                               Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <!--
                ══════════════════════════════════════════════════════════════
                SIMILARITY MAP PANEL
                ══════════════════════════════════════════════════════════════
            -->
            <Grid x:Name="SimilarityMapPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  Map toolbar  -->
                <Grid
                    Grid.Row="0"
                    Padding="12,8,12,8"
                    ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Copy buttons — visible only when a pivot icon is selected  -->
                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="4"
                        Visibility="{x:Bind local:MainPage.HasSelectedIcon(ViewModel.MapPivotIcon),
                                            Mode=OneWay}">
                        <Button
                            AutomationProperties.AutomationId="MapCopyGlyphButton"
                            AutomationProperties.Name="Copy glyph code"
                            Click="CopyGlyph_Click"
                            Content="&#xE8C8;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Copy glyph code" />
                        <Button
                            AutomationProperties.AutomationId="MapCopyXamlButton"
                            AutomationProperties.Name="Copy XAML FontIcon"
                            Command="{x:Bind ViewModel.CopyAsXamlCommand}"
                            Content="&#xE943;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Copy as XAML FontIcon" />
                        <Button
                            AutomationProperties.AutomationId="MapCopyPngButton"
                            AutomationProperties.Name="Copy PNG"
                            Click="CopyPng_Click"
                            Content="&#xEB9F;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Copy as PNG" />
                        <Button
                            AutomationProperties.AutomationId="MapCopySvgButton"
                            AutomationProperties.Name="Copy SVG"
                            Command="{x:Bind ViewModel.CopyAsSvgCommand}"
                            Content="&#xE71B;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            ToolTipService.ToolTip="Copy as SVG" />
                    </StackPanel>

                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        Opacity="0.7"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{x:Bind ViewModel.MapStatusText,
                                      Mode=OneWay}"
                        TextTrimming="CharacterEllipsis"
                        TextWrapping="NoWrap" />

                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Opacity="0.45"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Pinch/scroll to zoom · Drag to pan · Tap to set pivot" />
                </Grid>

                <!--  Map scatter-plot canvas  -->
                <canvas:CanvasControl
                    x:Name="MapCanvas"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="MapCanvas"
                    Draw="MapCanvas_Draw"
                    PointerCaptureLost="MapCanvas_PointerCaptureLost"
                    PointerMoved="MapCanvas_PointerMoved"
                    PointerPressed="MapCanvas_PointerPressed"
                    PointerReleased="MapCanvas_PointerReleased"
                    PointerWheelChanged="MapCanvas_PointerWheelChanged" />

                <!--  Empty-state hint  -->
                <TextBlock
                    x:Name="MapHintText"
                    Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Opacity="0.35"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="🗺  Click any icon to explore its visual neighborhood" />
            </Grid>

        </Grid>
    </NavigationView>
</Page>
